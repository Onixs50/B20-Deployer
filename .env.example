# کپی کن به .env و مقدارها رو پر کن. این فایل نباید commit بشه.

# از https://dashboard.reown.com یه پروژه بساز و Project ID رو اینجا بذار
VITE_REOWN_PROJECT_ID=

# بعد از دیپلوی کردن B20Launcher.sol روی هر شبکه (راهنمای README رو ببین)،
# آدرس قرارداد رو اینجا بذار.
VITE_LAUNCHER_ADDRESS_MAINNET=
VITE_LAUNCHER_ADDRESS_TESTNET=

# بعد از دیپلوی B20BatchDistributor.sol روی هر شبکه، آدرسش رو اینجا بذار.
# این کانترکت باعث می‌شه ارسال گروهی توی یک تراکنش انجام بشه، نه یکی‌یکی.
VITE_BATCH_DISTRIBUTOR_ADDRESS_MAINNET=
VITE_BATCH_DISTRIBUTOR_ADDRESS_TESTNET=

# بعد از دیپلوی contracts/robinhood/RHFactory.sol روی شبکه‌ی Robinhood Chain
# (مین‌نت و تست‌نت)، آدرسش رو اینجا بذار. این بخش کاملاً جدا از بخش B20/Base ـه.
VITE_RH_FACTORY_ADDRESS_MAINNET=
VITE_RH_FACTORY_ADDRESS_TESTNET=

# از https://app.pinata.cloud یه JWT با دسترسی pinFileToIPFS/pinJSONToIPFS بساز
VITE_PINATA_JWT=
VITE_PINATA_GATEWAY=https://gateway.pinata.cloud

# لینک‌های شخصی سازنده که پایین سایت نشون داده می‌شن (اختیاری)
VITE_CREATOR_TWITTER=https://x.com/your_handle
VITE_CREATOR_GITHUB=https://github.com/your_username
