# کپی کن به .env و مقدارها رو پر کن. این فایل نباید commit بشه.

# از https://dashboard.reown.com یه پروژه بساز و Project ID رو اینجا بذار
VITE_REOWN_PROJECT_ID=

# بعد از دیپلوی کردن B20Launcher.sol روی هر شبکه (راهنمای README رو ببین)،
# آدرس قرارداد رو اینجا بذار.
VITE_LAUNCHER_ADDRESS_MAINNET=
VITE_LAUNCHER_ADDRESS_TESTNET=

# از https://app.pinata.cloud یه JWT با دسترسی pinFileToIPFS/pinJSONToIPFS بساز
VITE_PINATA_JWT=
VITE_PINATA_GATEWAY=https://gateway.pinata.cloud
